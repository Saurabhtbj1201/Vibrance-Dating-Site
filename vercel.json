{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run -r build",
  "outputDirectory": "artifacts/dating-app/dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {}
}
